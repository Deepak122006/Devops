# ============================================================
# .env.example - Environment variable template for the DevSecOps stack
# WHY: The docker-compose.yml, Makefile, and jenkins.yaml all read
#      secrets from environment variables to keep credentials OUT of Git.
#
# USAGE:
#   cp .env.example .env
#   # Fill in your real values in .env
#   docker compose --env-file .env up -d
#
# IMPORTANT: .env is in .gitignore. NEVER commit real secrets.
# ============================================================

# ── AWS ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012        # Your 12-digit AWS account ID

# ── GitHub ─────────────────────────────────────────────────────
GIT_USER=your-github-username
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx     # GitHub Personal Access Token (repo + write)

# ── Jenkins ────────────────────────────────────────────────────
JENKINS_ADMIN_PASSWORD=ChangeMe@2024!
JENKINS_URL=http://YOUR_EC2_IP:8080    # Public URL for Slack/email links

# ── SonarQube ─────────────────────────────────────────────────
SONAR_HOST_URL=http://YOUR_EC2_IP:9000
SONAR_TOKEN=squ_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Generated by setup-sonarqube.sh
SONAR_DB_PASSWORD=sonarpass                         # PostgreSQL password for SonarQube

# ── Nexus ──────────────────────────────────────────────────────
NEXUS_URL=http://YOUR_EC2_IP:8081
NEXUS_USER=admin
NEXUS_PASSWORD=NexusAdmin@2024!        # Set by setup-nexus.sh
NEXUS_DEPLOY_USER=jenkins-deployer
NEXUS_DEPLOY_PASS=NexusDeploy@2024!   # Set by setup-nexus.sh
NEXUS_NEW_PASS=NexusAdmin@2024!

# ── ArgoCD ─────────────────────────────────────────────────────
ARGOCD_SERVER=YOUR_EKS_ARGOCD_LB_HOSTNAME    # Set by setup-argocd.sh
ARGOCD_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Generated by setup-argocd.sh

# ── Cosign ─────────────────────────────────────────────────────
# WHY: JCasC mounts the private key as a Secret File credential.
# base64-encode cosign.key AFTER running: bash cosign/cosign-setup.sh
# Then paste the output here.
# Generate it with: base64 -w 0 cosign/cosign.key
COSIGN_PRIVATE_KEY_B64=                        # base64-encoded cosign.key content

# ── Slack (optional) ───────────────────────────────────────────
SLACK_TEAM_DOMAIN=your-workspace              # e.g. "antigravity" for antigravity.slack.com
SLACK_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Slack Bot Token
